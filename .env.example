# ═══════════════════════════════════════════════════════
# Portal Revenda LC — Variáveis de Ambiente
# Copie este arquivo como .env e preencha os valores reais.
# NUNCA commite o arquivo .env com valores reais.
# ═══════════════════════════════════════════════════════

# URL pública do projeto Supabase
# Encontre em: Supabase → Settings → API → Project URL
SUPABASE_URL=https://SEU_PROJETO.supabase.co

# Chave anônima (pública) — usada no frontend
# Encontre em: Supabase → Settings → API → anon key
# Esta chave é segura para expor no frontend DESDE QUE o RLS esteja configurado corretamente.
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Variáveis usadas APENAS na Edge Function (não vão para o frontend) ──

# Chave de serviço (privada) — NUNCA expor no frontend
# Encontre em: Supabase → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Segredo HMAC-SHA256 para validar webhooks da Orion CRM
# Gere com: openssl rand -hex 32
# Configure em: Supabase → Edge Functions → webhook-orion → Secrets
ORION_WEBHOOK_SECRET=gere_um_segredo_forte_aqui

# Origens permitidas para CORS (separadas por vírgula)
# Ex: https://comercial-lc.github.io,https://meudominio.com
# Configure em: Supabase → Edge Functions → webhook-orion → Secrets
ALLOWED_ORIGINS=https://comercial-lc.github.io
